# Supabase — public (browser + server with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only (org bootstrap, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL for auth redirects (per environment)
# Local: http://localhost:3000
# Staging: https://staging.auroranexis.com
# Production: https://app.auroranexis.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron — server only (POST /api/cron/run)
CRON_SECRET=your-cron-bearer-secret

# Integration secrets vault — server only (64-char hex recommended)
INTEGRATION_SECRET_KEY=your-64-char-hex-integration-secret-key

# Resend — server only (report email delivery)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Auroranexis <reports@yourdomain.com>

# Stripe — billing (server secrets never expose to client except publishable key)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_WEBHOOK_SECRET_V2=whsec_your_webhook_v2_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_STARTER_PRICE_ID=price_your_starter_price
STRIPE_PROFESSIONAL_PRICE_ID=price_your_professional_price
STRIPE_BUSINESS_PRICE_ID=price_your_business_price
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price
STRIPE_PRICE_ID=price_your_default_subscription_price

# AI — server only (never use NEXT_PUBLIC prefix)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Connector OAuth — server only (configure per provider used in staging/production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# Cloudflare Turnstile — bot protection on login, signup, contact, support (production required)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# E2E only — set by Playwright webServer; never enable in production
# TURNSTILE_DISABLE=1
# E2E_DISABLE_RATE_LIMIT=1

# E2E — Playwright authenticated flows (preferred)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Legacy aliases — still supported
E2E_EMAIL=
E2E_PASSWORD=

# Pilot seed — optional override for scripts/seed-pilot-environment.mjs
PILOT_SEED_PASSWORD=

# Observability — optional (see docs/observability.md)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local development only — override resolved plan without changing Stripe (ignored in production)
# DEV_FORCE_PLAN=professional

# Billing provider switch — stripe (default) | paddle
# Keep stripe until Paddle sandbox price IDs + webhook are configured.
BILLING_PROVIDER=stripe

# Paddle Billing — server secrets never expose to client except NEXT_PUBLIC_PADDLE_CLIENT_TOKEN
# Sandbox until explicit production cutover approval. Names only — never commit real values.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Exactly: sandbox | production
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_PROFESSIONAL_MONTHLY=
PADDLE_PRICE_BUSINESS_MONTHLY=
# Optional — only if actually sold via Paddle (Enterprise remains quotation-first)
# PADDLE_PRICE_ENTERPRISE_MONTHLY=
# PADDLE_PRICE_PILOT_CLIENT=
# PADDLE_PRICE_FOUNDING=
# Webhook URL: https://auroranexis.com/api/paddle/webhook
