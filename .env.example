# Auroranexis environment template (Paddle-first)
# Copy to .env.local for development. Never commit real secrets.

# Supabase — public (browser + server with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL for auth redirects (per environment)
# Local: http://localhost:3000
# Staging: https://staging.auroranexis.com
# Production: https://app.auroranexis.com (or https://www.auroranexis.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron — server only (POST /api/cron/run)
CRON_SECRET=your-cron-bearer-secret

# Integration secrets vault — server only (64-char hex recommended)
INTEGRATION_SECRET_KEY=your-64-char-hex-integration-secret-key

# Email — server only (report delivery / notifications)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Auroranexis <reports@yourdomain.com>
# EMAIL_PROVIDER=resend

# Paddle Billing — sole active provider (server secrets never NEXT_PUBLIC except client token)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Exactly: sandbox | production
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_PROFESSIONAL_MONTHLY=
PADDLE_PRICE_BUSINESS_MONTHLY=
# Optional — only if sold via Paddle
# PADDLE_PRICE_ENTERPRISE_MONTHLY=
# PADDLE_PRICE_PILOT_CLIENT=
# PADDLE_PRICE_FOUNDING=
# Webhook URL: https://www.auroranexis.com/api/paddle/webhook

# AI — server only (never use NEXT_PUBLIC prefix)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Kill-switch: AI_PROVIDER=disabled

# Connector OAuth — server only (configure per provider used)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# E2E only — set by Playwright webServer; never enable in production
# E2E_DISABLE_RATE_LIMIT=1

# E2E — Playwright authenticated flows
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
# Legacy aliases
E2E_EMAIL=
E2E_PASSWORD=

# Pilot seed — optional
PILOT_SEED_PASSWORD=

# Observability — optional (see docs/observability.md)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Search Console / Bing Webmaster — paste verification tokens from each console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# IndexNow — server-only key for Bing/participating engines (served at /.well-known/{INDEXNOW_KEY}.txt)
INDEXNOW_KEY=

# Local development only — ignored when NODE_ENV=production
# DEV_FORCE_PLAN=professional

# Historical Stripe keys are NOT used for active billing. Do not configure for checkout.
# Archive/diagnostics may still reference historical stripe_* columns in the database.
